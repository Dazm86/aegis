# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to git.

# Supabase project settings (Project Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Free AI provider (Groq). Get a free key at https://console.groq.com/keys
AI_API_KEY=your-groq-api-key-here
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# Safety cap: max USD the system is allowed to spend per calendar month
# (stays 0 while you're on the free tier, matters once you switch to a paid provider)
MONTHLY_BUDGET_USD=5
